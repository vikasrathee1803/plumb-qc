<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Plumb estate roll-up{% if estate.manifest_ref %}: {{ estate.manifest_ref }}{% endif %}</title>
<style>
  :root {
    color-scheme: light dark;
    --bg-0:#07080c; --bg-1:#0b0d13; --bg-2:#0f1117; --bg-3:#14161f; --bg-4:#1a1d28;
    --line-1:#1d2030; --line-2:#2c3046;
    --fg-1:#ecedf3; --fg-2:#c4c8d3; --fg-3:#a0a6b5; --fg-4:#757a8c;
    --ai-1:#7c6bff; --ai-2:#a78bff; --ai-soft:rgba(124,107,255,0.14); --ai-edge:rgba(124,107,255,0.35);
    --pos:#3ddc97; --pos-soft:rgba(61,220,151,0.12);
    --neg:#ff6b7d; --neg-soft:rgba(255,107,125,0.12);
    --warn:#f5a524; --warn-soft:rgba(245,165,36,0.12);
    --info:#5aa9ff; --info-soft:rgba(90,169,255,0.12);
    --radius:14px;
    --font-sans:"Geist",ui-sans-serif,system-ui,-apple-system,"Segoe UI",sans-serif;
    --font-mono:"Geist Mono",ui-monospace,"JetBrains Mono",Menlo,monospace;
  }
  @media (prefers-color-scheme: light) {
    :root {
      --bg-0:#f8f9fb; --bg-1:#ffffff; --bg-2:#fafbfd; --bg-3:#f3f5f9; --bg-4:#e9edf3;
      --line-1:#e7e9ef; --line-2:#d4d8e0;
      --fg-1:#0f1117; --fg-2:#2c3046; --fg-3:#5a5f6e; --fg-4:#8a8f9c;
      --ai-1:#6b58f0; --ai-2:#5b48d6; --ai-soft:rgba(107,88,240,0.08); --ai-edge:rgba(107,88,240,0.25);
      --pos:#18a065; --pos-soft:rgba(24,160,101,0.10);
      --neg:#d63b50; --neg-soft:rgba(214,59,80,0.10);
      --warn:#c47d15; --warn-soft:rgba(214,132,29,0.12);
      --info:#2c6fd6; --info-soft:rgba(44,111,214,0.10);
    }
  }
  * { box-sizing: border-box; }
  body { margin:0; font-family:var(--font-sans); background:var(--bg-0); color:var(--fg-1);
    font-size:14px; line-height:1.5;
    background-image: radial-gradient(900px 500px at 80% -10%, var(--ai-soft), transparent 60%); }
  .shell { max-width:1100px; margin:0 auto; padding:28px 24px 60px; }
  .top { display:flex; align-items:baseline; gap:10px; margin-bottom:18px; }
  .logo { font-size:19px; font-weight:700; letter-spacing:-0.02em; }
  .logo .dot { color:var(--ai-1); }
  .top .tag { color:var(--fg-4); font-size:12px; }
  .card { background:var(--bg-1); border:1px solid var(--line-1); border-radius:var(--radius);
    padding:18px; margin-bottom:16px; }
  .hero { display:flex; align-items:center; gap:18px; padding:24px; border-radius:var(--radius);
    border:1px solid var(--line-2); }
  .v-BLOCKED { --vc:var(--neg); } .v-REVIEW { --vc:var(--warn); }
  .v-READY_WITH_NOTES { --vc:var(--info); } .v-READY { --vc:var(--pos); }
  .v-NONE { --vc:var(--fg-4); }
  .hero { background:linear-gradient(120deg, color-mix(in srgb, var(--vc) 12%, var(--bg-1)), var(--bg-1) 70%); }
  .hero .dot { width:14px; height:14px; border-radius:50%; background:var(--vc); box-shadow:0 0 14px var(--vc); }
  .hero .vbig { font-size:30px; font-weight:800; letter-spacing:-0.02em; color:var(--vc); }
  .hero .vmeta { color:var(--fg-3); font-size:13px; } .hero .vmeta b { color:var(--fg-1); }
  .tiles { display:grid; grid-template-columns:repeat(auto-fit,minmax(90px,1fr)); gap:10px; margin-top:16px; }
  .tile { background:var(--bg-2); border:1px solid var(--line-1); border-radius:10px; padding:12px; text-align:center; }
  .tile .n { font-size:22px; font-weight:700; } .tile .l { font-size:11px; color:var(--fg-4); text-transform:uppercase; letter-spacing:0.05em; }
  .t-ready .n { color:var(--pos); } .t-blocked .n { color:var(--neg); }
  .t-review .n { color:var(--warn); } .t-notes .n { color:var(--info); } .t-err .n { color:var(--ai-2); }
  h4 { margin:0 0 8px; font-size:13px; }
  table.wb { width:100%; border-collapse:collapse; font-size:13px; }
  table.wb th, table.wb td { text-align:left; padding:8px 10px; border-bottom:1px solid var(--line-1); vertical-align:top; }
  table.wb th { color:var(--fg-4); font-size:11px; text-transform:uppercase; letter-spacing:0.05em; }
  td.mono { font-family:var(--font-mono); font-size:12px; color:var(--fg-2); }
  .pill { display:inline-block; font-size:11px; font-weight:700; padding:3px 9px; border-radius:999px; min-width:52px; text-align:center; }
  .p-READY { background:var(--pos-soft); color:var(--pos); }
  .p-BLOCKED { background:var(--neg-soft); color:var(--neg); }
  .p-REVIEW { background:var(--warn-soft); color:var(--warn); }
  .p-READY_WITH_NOTES { background:var(--info-soft); color:var(--info); }
  .p-ERROR { background:var(--ai-soft); color:var(--ai-2); }
  .p-NONE { background:var(--bg-4); color:var(--fg-4); }
  .err { color:var(--neg); font-size:12px; font-family:var(--font-mono); }
  footer { color:var(--fg-4); font-size:12px; text-align:center; padding-top:8px; }
</style>
</head>
<body>
<div class="shell">
  <div class="top">
    <span class="logo">plumb<span class="dot">.</span></span>
    <span class="tag">estate roll-up</span>
  </div>

  <div class="card hero v-{{ rollup }}">
    <span class="dot"></span>
    <div>
      <div class="vbig">{{ rollup_label }}</div>
      <div class="vmeta">
        phase <b>{{ estate.phase }}</b>
        {% if estate.manifest_ref %} &middot; manifest <b>{{ estate.manifest_ref }}</b>{% endif %}
        &middot; {{ estate.created_at }}
      </div>
      <div class="vmeta"><b>{{ counts.total }}</b> workbooks &middot;
        {{ counts.blocked }} blocked &middot; {{ counts.review }} review &middot;
        {{ counts.notes }} ready with notes &middot; {{ counts.ready }} ready &middot;
        {{ counts.errored }} errored</div>
    </div>
  </div>

  <div class="card">
    <div class="tiles">
      <div class="tile t-ready"><div class="n">{{ counts.ready }}</div><div class="l">ready</div></div>
      <div class="tile t-notes"><div class="n">{{ counts.notes }}</div><div class="l">with notes</div></div>
      <div class="tile t-review"><div class="n">{{ counts.review }}</div><div class="l">review</div></div>
      <div class="tile t-blocked"><div class="n">{{ counts.blocked }}</div><div class="l">blocked</div></div>
      <div class="tile t-err"><div class="n">{{ counts.errored }}</div><div class="l">errored</div></div>
    </div>
  </div>

  <div class="card">
    <h4>Workbooks ({{ counts.total }})</h4>
    <table class="wb">
      <thead>
        <tr><th>Workbook</th><th>Map</th><th>Snapshot</th><th>Check</th><th>Worst</th><th>Error</th></tr>
      </thead>
      <tbody>
      {% for row in rows %}
        <tr>
          <td class="mono">{{ row.path }}</td>
          <td class="mono">{{ row.map }}</td>
          <td><span class="pill p-{{ row.snapshot or 'NONE' }}">{{ row.snapshot or '-' }}</span></td>
          <td><span class="pill p-{{ row.check or 'NONE' }}">{{ row.check or '-' }}</span></td>
          <td><span class="pill p-{{ row.worst or 'NONE' }}">{{ row.worst or '-' }}</span></td>
          <td class="err">{{ row.error }}</td>
        </tr>
      {% endfor %}
      </tbody>
    </table>
  </div>

  <footer>
    Plumb {{ plumb_version }} &middot; deterministic verdict, no AI in the verdict path
  </footer>
</div>
</body>
</html>
